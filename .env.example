# === Database ===
DATABASE_URL=postgresql+asyncpg://app:password@db-xxxxx.tmwb.cloud:5432/ai_visibility
DATABASE_URL_SYNC=postgresql://app:password@db-xxxxx.tmwb.cloud:5432/ai_visibility

# === Redis ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === LLM APIs ===
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=...
PERPLEXITY_API_KEY=...

YANDEX_API_KEY=...
YANDEX_FOLDER_ID=...

GIGACHAT_AUTH_KEY=...

# === XMLRiver SERP API (для Алисы) ===
XMLRIVER_USER=12345
XMLRIVER_KEY=abc...
XMLRIVER_REGION_RU=213
XMLRIVER_REGION_BY=157

# === Pipeline settings ===
ENABLED_MODELS=chatgpt,yandexgpt,yandex_ai_search,gigachat,gemini,deepseek,perplexity
PROMPTS_PER_REPORT=10
COMPETITORS_PER_REPORT=5
CACHE_TTL_DAYS=7
DAILY_REPORT_LIMIT=20

# === Срочные фиксы: дедуп по домену + лимиты на запуск анализа ===
# Сколько дней переиспользуем готовый отчёт по тому же домену (не пересчитываем):
REPORT_REUSE_DAYS=30
# Жёсткие лимиты на РЕАЛЬНЫЕ запуски (защита денег на API):
MAX_ANALYSES_PER_EMAIL_PER_DAY=2
MAX_ANALYSES_PER_IP_PER_DAY=5
MAX_ANALYSES_PER_IP_PER_HOUR=3

# === Rate limits (legacy, через Redis) ===
RATE_LIMIT_PER_DOMAIN_COUNT=2
RATE_LIMIT_PER_DOMAIN_BRAND_DAYS=30
RATE_LIMIT_PER_EMAIL_DAYS=30
RATE_LIMIT_PER_FINGERPRINT_DAYS=30
RATE_LIMIT_PER_IP_HOURS=24
RATE_LIMIT_PER_VPN_DAYS=90

# === Per-model rate limits (RPM) ===
OPENAI_MAX_RPM=400
GEMINI_MAX_RPM=12
DEEPSEEK_MAX_RPM=60
YANDEX_MAX_RPM=100
GIGACHAT_MAX_RPM=50
PERPLEXITY_MAX_RPM=50
ALISA_MAX_RPM=100

# === Celery ===
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=600

# === S3 (Timeweb Cloud Object Storage) ===
S3_ENDPOINT_URL=https://s3.timeweb.cloud
S3_ACCESS_KEY=...
S3_SECRET_KEY=...
S3_BUCKET=ai-visibility-reports
S3_REGION=ru-1

# === Email (SMTP Timeweb) ===
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=noreply@catcore.ru
SMTP_PASSWORD=...
FROM_EMAIL=noreply@catcore.ru
SUPPORT_EMAIL=support@catcore.ru
CONTACT_EMAIL=info@catcore.ru

# === Cloudflare Turnstile (защита от ботов) ===
# Если SECRET задан — бэкенд РЕАЛЬНО проверяет токен (без токена → 403).
# Если пусто — проверка пропускается (dev). Получить ключи: dash.cloudflare.com → Turnstile.
TURNSTILE_SITE_KEY=...
TURNSTILE_SECRET_KEY=...
# ВАЖНО: фронту нужен тот же site key в его .env:
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=...
# Иначе виджет не отрендерится и капча не заработает.

# === IP Quality Check ===
IPAPI_KEY=...

# === Sentry ===
SENTRY_DSN=...

# === Студия и эксперт ===
EXPERT_NAME=[EXPERT_NAME]
EXPERT_FIRST_NAME=[EXPERT_FIRST_NAME]
EXPERT_LAST_NAME=[EXPERT_LAST_NAME]
EXPERT_TITLE=[EXPERT_TITLE]
EXPERT_PHOTO_URL=[EXPERT_PHOTO_URL]
EXPERT_BIO_SHORT=[EXPERT_BIO_SHORT]

STUDIO_NAME=Cat Core
STUDIO_NAME_FULL=Cat Core — студия GEO-продвижения [EXPERT_NAME]
STUDIO_DOMAIN=catcore.ru
STUDIO_FULL_URL=https://catcore.ru
STUDIO_LOGO_URL=https://catcore.ru/logo.svg
STUDIO_FOUNDED_YEAR=2025
STUDIO_CITY=Минск
STUDIO_COUNTRY_CODE=BY

CONTACT_TG_BOT=@catcore_sitebot
CONTACT_TG_BOT_URL=https://t.me/catcore_sitebot

# === Telegram-бот ===
TELEGRAM_BOT_TOKEN=...
TELEGRAM_NOTIFY_CHAT_ID=...
# Если api.telegram.org недоступен с VPS (некоторые RU-провайдеры режут),
# разверни бесплатный Cloudflare Worker relay (infra/cloudflare-workers/telegram-relay.js)
# и впиши его URL сюда. Иначе оставь как есть.
TELEGRAM_API_BASE=https://api.telegram.org
# (опционально) http/socks-прокси — альтернатива relay
TELEGRAM_PROXY_URL=

# === Workflow эксперта ===
EXPERT_REVIEW_BEFORE_SEND=true
EXPERT_REVIEW_TIMEOUT_MINUTES=30

# === Internal API security ===
INTERNAL_API_TOKEN=change-me-to-random-secret

# === Google Sheets CRM ===
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/google-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=1AbCdEfGh...

# === CRM ===
# Bitrix24 убран: на бесплатном тарифе нет ни REST API, ни виджета записи.
# CRM-роль — Google Sheets (выше). Заявки на разговор собирает наша форма
# /zapis-na-razgovor и шлёт эксперту в Telegram.

# === App ===
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-random-secret-key
